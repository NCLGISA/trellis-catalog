# Tendril agent registration
TENDRIL_INSTALL_KEY=your-install-key-here
TENDRIL_DOWNLOAD_URL=https://your-tendril-root/download/tendril?linux-amd64

# Bridge seed version (bump to re-seed tools/skills on container restart)
BRIDGE_SEED_VERSION=2026.03.07.1

# Verizon credentials are per-operator and stored in the Tendril credential vault.
# They are NOT set here -- use bridge_credentials() instead:
#
#   bridge_credentials(action="set", bridge="verizon-mybusiness", key="VZ_USERNAME", value="<username>")
#   bridge_credentials(action="set", bridge="verizon-mybusiness", key="VZ_PASSWORD", value="<password>")
#
# The following are injected automatically by the vault at runtime:
# VZ_USERNAME=
# VZ_PASSWORD=
