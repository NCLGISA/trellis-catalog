# NAVEX PolicyTech bridge environment variables

# Tendril agent registration key (from your Tendril Root admin panel)
TENDRIL_INSTALL_KEY=

# Tendril agent download URL
TENDRIL_DOWNLOAD_URL=https://your-tendril-root/download/tendril?linux-amd64

# NAVEX One PolicyTech base URL (no trailing slash)
# Determine from your login URL: https://yourorg.navexone.com
# See references/README.md Step 1 for details.
POLICYTECH_BASE_URL=

# API key from Settings & Tools > IT Settings > API Keys
# The API Keys add-on must be enabled by NAVEX Support first.
POLICYTECH_API_KEY=

# TLS certificate verification (default: true)
POLICYTECH_VERIFY_TLS=true
