# Tendril Bridge - Microsoft Teams Bot Configuration
# Copy to .env and fill in values.

TENDRIL_INSTALL_KEY=
TENDRIL_DOWNLOAD_URL=https://your-tendril-root/download/tendril?linux-amd64

# Bot Framework Authentication (client secret, not certificate)
#
# Required Entra setup:
#   1. App registration (single-tenant: "Accounts in this organizational directory only")
#   2. Client secret created for the app
#   3. Azure Bot Service resource created and linked to this app
#   4. Teams channel enabled on the Azure Bot Service
#   5. Graph API permissions (Application):
#      - Chat.Read.All           (enumerate user chats)
#      - ChatMessage.Read.All    (read all chat messages)
#      - ChannelMessage.Read.All (read all channel messages)
#      - User.Read.All           (enumerate users for chat access)
#      - Team.ReadBasic.All      (list teams)
#      - Channel.ReadBasic.All   (list channels)
#   6. Admin consent granted for all permissions
#
# Run references/setup_teams_bot.sh for automated setup.
TEAMS_BOT_APP_ID=
TEAMS_BOT_APP_SECRET=
TEAMS_BOT_TENANT_ID=

# Bot display name shown in Teams conversations
TEAMS_BOT_NAME=Tendril Bot

# Operating mode: 'webhook' (default) or 'polling'
#   webhook: Full Bot Framework with cloudflared tunnel -- real-time messages,
#            proactive sends, and Graph API reads. Requires CLOUDFLARE_TUNNEL_TOKEN.
#   polling: Graph API reads only -- no real-time receipt, no proactive send.
TEAMS_BOT_MODE=webhook

# Bot server port (webhook mode only, default: 3978)
TEAMS_BOT_PORT=3978

# Cloudflare tunnel token (required for webhook mode)
# Create a tunnel at https://one.dash.cloudflare.com/ -> Networks -> Tunnels
# Route the tunnel to http://localhost:3978
CLOUDFLARE_TUNNEL_TOKEN=

BRIDGE_SEED_VERSION=1
