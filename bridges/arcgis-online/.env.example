# arcgis-online bridge environment variables

# Tendril agent registration key (from your Tendril Root admin panel)
TENDRIL_INSTALL_KEY=

# Tendril agent download URL
TENDRIL_DOWNLOAD_URL=https://your-tendril-root/download/tendril?linux-amd64

# ArcGIS Online organization URL (e.g. https://orgname.maps.arcgis.com). This is the portal URL for your ArcGIS Online organization.

ARCGIS_ORG_URL=

# OAuth2 application client ID. Create an app at developers.arcgis.com or in your org's Application settings. The app needs privileges for the API surfaces this bridge uses.

ARCGIS_CLIENT_ID=

# OAuth2 application client secret. Paired with the client ID for the client_credentials grant flow (server-to-server).

ARCGIS_CLIENT_SECRET=
