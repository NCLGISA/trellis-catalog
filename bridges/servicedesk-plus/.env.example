# ServiceDesk Plus Cloud bridge configuration
#
# SDP instance URL (required, shared across all operators)
# SDP_INSTANCE_URL=https://yourorg.sdpondemand.manageengine.com
#
# Zoho accounts URL (optional, default: https://accounts.zoho.com)
# Override for non-US Zoho regions: .eu, .in, .com.au, .com.cn
# SDP_ZOHO_URL=https://accounts.zoho.com
#
# Tendril agent install key (set during first deployment)
# TENDRIL_INSTALL_KEY=your_install_key
#
# Tendril agent download URL (auto-detected if omitted)
# TENDRIL_DOWNLOAD_URL=https://your-tendril-root/download/tendril?linux-amd64
#
# Per-operator OAuth credentials (injected via Tendril bridge_credentials vault)
# SDP_CLIENT_ID=your_zoho_client_id
# SDP_CLIENT_SECRET=your_zoho_client_secret
# SDP_REFRESH_TOKEN=your_zoho_refresh_token
