# Tendril Bridge - Microsoft Defender Configuration
# Copy to .env and fill in values.

TENDRIL_INSTALL_KEY=
TENDRIL_DOWNLOAD_URL=https://your-tendril-root/download/tendril?linux-amd64

# Entra ID App Registration (single registration for all three API surfaces)
#
# Required Entra setup:
#   1. App registration (single-tenant)
#   2. Client secret created for the app
#   3. API permissions granted and admin-consented:
#
#      Microsoft Threat Protection (Defender XDR):
#        - AdvancedHunting.Read.All    (advanced hunting across all tables)
#        - Incident.ReadWrite.All      (incident management)
#        - Alert.ReadWrite.All         (alert management)
#
#      WindowsDefenderATP (MDE):
#        - Machine.ReadWrite.All              (machine inventory + response actions)
#        - Vulnerability.Read.All             (TVM: CVEs, software)
#        - SecurityRecommendation.Read.All    (TVM: security recommendations)
#        - AdvancedQuery.Read.All             (MDE-specific advanced queries)
#        - Ti.ReadWrite.All                   (threat indicator management)
#        - Alert.ReadWrite.All                (MDE alert management)
#        - Software.Read.All                  (software inventory)
#
#   4. ARM RBAC roles assigned on the Sentinel workspace resource group:
#        - Microsoft Sentinel Contributor
#        - Log Analytics Reader
#
# Run references/setup_defender_bridge.sh for automated setup.
AZURE_TENANT_ID=
DEFENDER_CLIENT_ID=
DEFENDER_CLIENT_SECRET=

# Sentinel / Log Analytics (optional -- omit for MDE-only deployments)
# These enable Sentinel analytics rules, watchlists, automation rules,
# and direct KQL queries against the Log Analytics workspace.
SENTINEL_SUBSCRIPTION_ID=
SENTINEL_RESOURCE_GROUP=
SENTINEL_WORKSPACE_NAME=
SENTINEL_WORKSPACE_ID=

BRIDGE_SEED_VERSION=1
