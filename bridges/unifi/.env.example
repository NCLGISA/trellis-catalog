# unifi bridge environment variables

# Tendril agent registration key (from your Tendril Root admin panel)
TENDRIL_INSTALL_KEY=

# Tendril agent download URL
TENDRIL_DOWNLOAD_URL=https://your-tendril-root/download/tendril?linux-amd64

# Base URL of the UniFi Network Controller (e.g. https://unifi.example.com:8443 for standard controllers, or https://192.168.1.1 for UniFi OS gateways).

UNIFI_URL=

# Local admin username for the UniFi controller.
UNIFI_USERNAME=

# Password for the UniFi controller admin account.
UNIFI_PASSWORD=

# Default site name (default: "default"). Used when no --site argument is provided to tool scripts.

UNIFI_SITE=

