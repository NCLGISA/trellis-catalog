# Confluence Cloud bridge environment variables

# Tendril agent registration key (from your Tendril Root admin panel)
TENDRIL_INSTALL_KEY=

# Tendril agent download URL
TENDRIL_DOWNLOAD_URL=https://your-tendril-root/download/tendril?linux-amd64

# Atlassian site URL (no trailing slash)
CONFLUENCE_URL=https://yourorg.atlassian.net

# Per-operator credentials are injected via Tendril bridge_credentials,
# not set here. Each operator stores their own email + API token:
#   CONFLUENCE_EMAIL       -- Atlassian account email
#   CONFLUENCE_API_TOKEN   -- API token from https://id.atlassian.com/manage-profile/security/api-tokens
