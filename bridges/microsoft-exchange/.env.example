# ============================================================================
# Tendril Bridge - Microsoft Exchange Configuration
# ============================================================================
# Copy to .env and fill in values. Never commit .env to version control.
# ============================================================================

# Tendril installation key (from admin panel /admin > Install page)
# Only needed on first run -- after registration, tendril.json persists in volume
TENDRIL_INSTALL_KEY=

# Tendril agent download URL
TENDRIL_DOWNLOAD_URL=https://your-tendril-root/download/tendril?linux-amd64

# Exchange Online PowerShell - Certificate-Based Authentication
#
# Required Entra setup:
#   1. App registration with self-signed certificate uploaded
#   2. Service principal created for the app
#   3. Exchange Administrator directory role assigned to the SP
#   4. API permission: Office 365 Exchange Online > Exchange.ManageAsApp (Role)
#      with admin consent granted
#
# Run references/setup_exchange_bridge.sh to automate all of the above.
#
# The certificate file (exchange-bridge.pfx) must be in the certs/ directory.
EXO_TENANT_ID=
EXO_APP_ID=
EXO_CERT_THUMBPRINT=
EXO_ORGANIZATION=contoso.onmicrosoft.com

# Bump to force re-seed of tools/skills on image rebuild
BRIDGE_SEED_VERSION=1
