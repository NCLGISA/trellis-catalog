# Microsoft Graph bridge environment variables

# Tendril agent registration key (from your Tendril Root admin panel)
TENDRIL_INSTALL_KEY=

# Tendril agent download URL
TENDRIL_DOWNLOAD_URL=https://your-tendril-root/download/tendril?linux-amd64

# Entra ID tenant ID for MSAL client_credentials authentication
AZURE_TENANT_ID=

# App registration client ID with Graph API application permissions
AZURE_CLIENT_ID=

# App registration client secret
AZURE_CLIENT_SECRET=

# Bump to force re-seed of tools/skills on image rebuild
BRIDGE_SEED_VERSION=1

