# microsoft-graph bridge environment variables

# Tendril agent registration key (from your Tendril Root admin panel)
TENDRIL_INSTALL_KEY=

# Tendril agent download URL
TENDRIL_DOWNLOAD_URL=https://your-tendril-root/download/tendril?linux-amd64

# Entra ID tenant ID for app registration authentication
AZURE_TENANT_ID=

# App registration client ID with Graph API permissions
GRAPH_CLIENT_ID=

# App registration client secret
GRAPH_CLIENT_SECRET=

