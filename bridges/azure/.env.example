# Azure Resource Manager bridge environment variables

# Tendril agent registration key (from your Tendril Root admin panel)
TENDRIL_INSTALL_KEY=
# Tendril agent download URL
TENDRIL_DOWNLOAD_URL=https://your-tendril-root/download/tendril?linux-amd64

# Azure cloud: "usgovernment" or "commercial"
AZURE_CLOUD=usgovernment

# Entra ID tenant (from portal.azure.us for Gov, portal.azure.com for commercial)
AZURE_TENANT_ID=

# App registration credentials (service principal)
ARM_CLIENT_ID=
ARM_CLIENT_SECRET=

# Azure subscription ID
AZURE_SUBSCRIPTION_ID=
