# Generated by trellis -- regenerated on each build
# Bridge: azure v2026.02.19.1
FROM tendril-bridge-base:latest

ARG BRIDGE_SEED_VERSION=2
ENV BRIDGE_SEED_VERSION=${BRIDGE_SEED_VERSION}

RUN pip install --no-cache-dir requests>=2.31.0 python-dotenv>=1.0.0 msal>=1.28.0

# Install Azure CLI (pin to bookworm -- trixie not yet in MS repo)
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        ca-certificates curl gnupg \
        procps iputils-ping iproute2 dnsutils net-tools traceroute && \
    mkdir -p /etc/apt/keyrings && \
    curl -sLS https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor -o /etc/apt/keyrings/microsoft.gpg && \
    chmod go+r /etc/apt/keyrings/microsoft.gpg && \
    echo "deb [arch=amd64 signed-by=/etc/apt/keyrings/microsoft.gpg] https://packages.microsoft.com/repos/azure-cli/ bookworm main" > /etc/apt/sources.list.d/azure-cli.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends azure-cli && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

COPY tools/ /opt/bridge/_seed/tools/
COPY skills/ /opt/bridge/_seed/skills/

COPY tools/az_entrypoint.sh /opt/bridge/az_entrypoint.sh
RUN chmod +x /opt/bridge/az_entrypoint.sh

ENTRYPOINT ["/opt/bridge/az_entrypoint.sh"]
