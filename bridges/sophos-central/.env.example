# Sophos Central bridge environment variables

# Tendril agent registration key (from your Tendril Root admin panel)
TENDRIL_INSTALL_KEY=

# Tendril agent download URL
TENDRIL_DOWNLOAD_URL=https://your-tendril-root/download/tendril?linux-amd64

# Sophos Central OAuth2 credentials
# Create at: Sophos Central Admin > Global Settings > API Credentials Management
SOPHOS_CLIENT_ID=
SOPHOS_CLIENT_SECRET=
