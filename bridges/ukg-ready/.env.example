# UKG Ready bridge environment variables

# Tendril agent registration key (from your Tendril Root admin panel)
TENDRIL_INSTALL_KEY=

# Tendril agent download URL
TENDRIL_DOWNLOAD_URL=https://your-tendril-root/download/tendril?linux-amd64

# UKG Ready API host URL (no trailing slash)
# Determine your host from your login URL: https://secureN.saashr.com
# See references/README.md Step 5 for detailed instructions.
UKG_BASE_URL=

# 7-digit company identifier from your login URL or Company Setup > Company Info
UKG_COMPANY_SHORT_NAME=

# REST API key from Company Setup > Login Config > API Keys
# WARNING: generating a new key invalidates the previous one
UKG_API_KEY=

# Service account credentials (Company Setup > Login Config > Service Accounts)
UKG_USERNAME=
UKG_PASSWORD=

# TLS certificate verification (default: true)
# Set to "false" for environments using self-signed certificates
UKG_VERIFY_TLS=true
