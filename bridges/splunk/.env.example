# Splunk bridge environment variables

# Tendril agent registration key (from your Tendril Root admin panel)
TENDRIL_INSTALL_KEY=

# Tendril agent download URL
TENDRIL_DOWNLOAD_URL=https://your-tendril-root/download/tendril?linux-amd64

# Splunk search head URL (include port 8089)
# Cloud:   https://yourorg.splunkcloud.com:8089
# On-prem: https://splunk.internal:8089
SPLUNK_URL=

# Splunk authentication token (Settings > Tokens in Splunk Web)
# Tokens are per-user and inherit the creating user's roles and index permissions
SPLUNK_TOKEN=

# TLS certificate verification (default: true)
# Set to "false" for on-prem instances using self-signed certificates
SPLUNK_VERIFY_TLS=true
