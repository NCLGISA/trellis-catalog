# NextDNS bridge environment variables

# Tendril agent registration key (from your Tendril Root admin panel)
TENDRIL_INSTALL_KEY=

# Tendril agent download URL
TENDRIL_DOWNLOAD_URL=https://your-tendril-root/download/tendril?linux-amd64

# NextDNS API key (from https://my.nextdns.io/account, bottom of page)
NEXTDNS_API_KEY=

# Default NextDNS profile ID (optional, e.g. abc123)
# Find profile IDs in the NextDNS dashboard URL or via "profiles list"
NEXTDNS_PROFILE=
